<!-- 嗅嗅浏览器 - 深色主题资源字典 -->
<!-- 定义深色模式下的所有颜色和画刷资源 -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 颜色定义 ===== -->
    <!-- 窗口背景色：深黑灰，减少眼睛疲劳 -->
    <Color x:Key="WindowBackgroundColor">#1E1E1E</Color>
    <!-- 卡片/控件背景色：中深灰，提供层次感 -->
    <Color x:Key="CardBackgroundColor">#2D2D2D</Color>
    <!-- 面板背景色：略浅于窗口背景 -->
    <Color x:Key="PanelBackgroundColor">#252525</Color>
    <!-- 主要文本颜色：浅白，确保在深色背景下的可读性 -->
    <Color x:Key="TextPrimaryColor">#E8E8E8</Color>
    <!-- 次要文本颜色：中灰白，用于描述信息 -->
    <Color x:Key="TextSecondaryColor">#999999</Color>
    <!-- 强调色：与浅色主题保持一致 -->
    <Color x:Key="AccentColor">#319FDE</Color>
    <!-- 边框颜色：深灰，微妙的边界区分 -->
    <Color x:Key="BorderBrushColor">#3D3D3D</Color>

    <!-- 补充颜色 - 深色模式适配 -->
    <!-- 悬停背景色 -->
    <Color x:Key="HoverBackgroundColor">#3A3A3A</Color>
    <!-- 按下背景色 -->
    <Color x:Key="PressedBackgroundColor">#454545</Color>
    <!-- 危险/错误颜色（深色模式稍微调亮） -->
    <Color x:Key="DangerColor">#E74C3C</Color>
    <!-- 成功颜色 -->
    <Color x:Key="SuccessColor">#2ECC71</Color>
    <!-- 警告颜色 -->
    <Color x:Key="WarningColor">#F1C40F</Color>

    <!-- ===== 画刷定义 ===== -->
    <!-- 窗口背景画刷 -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <!-- 卡片背景画刷 -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <!-- 面板背景画刷 -->
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <!-- 主要文本画刷 -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <!-- 次要文本画刷 -->
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <!-- 强调色画刷 -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <!-- 边框画刷 -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderBrushColor}"/>

    <!-- 补充画刷 -->
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{StaticResource HoverBackgroundColor}"/>
    <SolidColorBrush x:Key="PressedBackgroundBrush" Color="{StaticResource PressedBackgroundColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>

    <!-- 语义别名画刷（保持向后兼容） -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverBackgroundColor}"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#2B8AC5"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#555555"/>
    <SolidColorBrush x:Key="PanelHeaderBrush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="TitleBarBrush" Color="#1A1A1A"/>

    <!-- 透明画刷 -->
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

</ResourceDictionary>
