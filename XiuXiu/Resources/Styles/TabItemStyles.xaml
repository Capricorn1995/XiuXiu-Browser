<!-- 嗅嗅浏览器 - 标签页样式资源字典 -->
<!-- 定义浏览器标签页的视觉样式，包含关闭按钮 -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 标签页容器样式 ===== -->
    <!-- 定义 TabControl 的整体外观 -->
    <Style x:Key="BrowserTabControlStyle" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- 标签页头部区域 -->
                        <Border Grid.Row="0"
                                Background="{StaticResource PanelBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="HeaderPanel"
                                            Orientation="Horizontal"
                                            IsItemsHost="True"/>
                            </ScrollViewer>
                        </Border>
                        <!-- 标签页内容区域 -->
                        <Border Grid.Row="1"
                                Background="{StaticResource CardBackgroundBrush}">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 单个标签页项样式 ===== -->
    <!-- 包含标签标题、favicon 和关闭按钮 -->
    <Style x:Key="BrowserTabItemStyle" TargetType="TabItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="MaxWidth" Value="200"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="tabBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1,1,1,0"
                            CornerRadius="6,6,0,0"
                            Margin="1,4,0,0"
                            Padding="8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Favicon 图标 -->
                            <Image x:Name="faviconImage"
                                   Grid.Column="0"
                                   Width="16"
                                   Height="16"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center"
                                   Stretch="Uniform"/>
                            <!-- 标签标题 -->
                            <TextBlock x:Name="titleText"
                                       Grid.Column="1"
                                       Text="{TemplateBinding Header}"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="140"/>
                            <!-- 关闭按钮 -->
                            <Button x:Name="closeButton"
                                    Grid.Column="2"
                                    Width="18"
                                    Height="18"
                                    Margin="4,0,0,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="10"
                                    Cursor="Hand"
                                    VerticalAlignment="Center"
                                    Content="✕"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- 选中状态：高亮背景，深色文字 -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="tabBorder" Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
                            <Setter TargetName="tabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            <Setter TargetName="titleText" Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Setter TargetName="titleText" Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                        <!-- 鼠标悬停：浅色背景 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="tabBorder" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
