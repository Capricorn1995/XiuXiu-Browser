<!-- 嗅嗅浏览器 - 标签页条视图 -->
<!-- 水平滚动的标签页列表，每个标签页显示图标、标题和关闭按钮 -->
<UserControl x:Class="XiuXiu.Views.TabStripView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:XiuXiu.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <!-- 标签页栏布局：可滚动的标签页列表 + 新建标签页按钮 -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- 标签页列表（水平滚动） -->
        <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Tabs}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- 单个标签页 -->
                        <Border x:Name="TabBorder"
                                MinWidth="160"
                                MaxWidth="240"
                                Height="36"
                                Margin="2,4,0,0"
                                Padding="10,0"
                                Background="Transparent"
                                CornerRadius="8,8,0,0"
                                Cursor="Hand"
                                MouseLeftButtonDown="TabItem_MouseLeftButtonDown">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>  <!-- 图标 -->
                                    <ColumnDefinition Width="*"/>     <!-- 标题 -->
                                    <ColumnDefinition Width="Auto"/>  <!-- 关闭按钮 -->
                                </Grid.ColumnDefinitions>

                                <!-- 网站图标 -->
                                <Image Grid.Column="0" Width="16" Height="16"
                                       Source="{Binding FaviconUrl}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"
                                       Stretch="Uniform"/>

                                <!-- 标签页标题 -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Title}"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Title}"/>

                                <!-- 关闭按钮 -->
                                <Button Grid.Column="2" Content="×"
                                        Width="20" Height="20"
                                        FontSize="12"
                                        Background="Transparent"
                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Margin="4,0,0,0"
                                        Click="CloseTabButton_Click"
                                        Tag="{Binding}"
                                        ToolTip="关闭标签页 (Ctrl+W)">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="Transparent" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- 活动标签页高亮样式触发器 -->
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding TabId}"
                                         Value="{Binding DataContext.ActiveTab.TabId, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <Setter TargetName="TabBorder" Property="Background"
                                        Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,0,0,2"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 新建标签页按钮 -->
        <Button Grid.Column="1" Content="+"
                Width="32" Height="32"
                FontSize="18"
                Background="Transparent"
                Foreground="{DynamicResource PrimaryTextBrush}"
                BorderThickness="0"
                Cursor="Hand"
                Margin="4,0,8,0"
                Command="{Binding AddNewTabCommand}"
                ToolTip="新建标签页 (Ctrl+T)">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="Transparent" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
