<!-- 嗅嗅浏览器 - 书签管理视图 -->
<!-- 展示和管理用户书签 -->
<UserControl x:Class="XiuXiu.Views.BookmarkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:XiuXiu.Converters"
             xmlns:models="clr-namespace:XiuXiu.Models"
             Width="360">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <!-- 书签面板布局 -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 头部 -->
            <RowDefinition Height="Auto"/>  <!-- 搜索和筛选 -->
            <RowDefinition Height="*"/>     <!-- 书签列表 -->
            <RowDefinition Height="Auto"/>  <!-- 添加按钮 -->
        </Grid.RowDefinitions>

        <!-- ===== 头部 ===== -->
        <Border Grid.Row="0" Padding="12,10"
                Background="{DynamicResource PanelHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="★" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="书签" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ===== 搜索和筛选 ===== -->
        <StackPanel Grid.Row="1" Margin="12,8">
            <!-- 搜索输入框 -->
            <TextBox Height="28"
                     Background="{DynamicResource InputBackgroundBrush}"
                     Foreground="{DynamicResource PrimaryTextBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     Padding="8,4" FontSize="12"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="搜索书签"/>

            <!-- 文件夹下拉筛选 -->
            <ComboBox Margin="0,8,0,0" Height="28"
                      ItemsSource="{Binding Folders}"
                      SelectedItem="{Binding SelectedFolder}"
                      Background="{DynamicResource InputBackgroundBrush}"
                      Foreground="{DynamicResource PrimaryTextBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      FontSize="12"
                      ToolTip="按文件夹筛选"/>
        </StackPanel>

        <!-- ===== 书签列表 ===== -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <ItemsControl ItemsSource="{Binding Bookmarks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:BookmarkItem}">
                            <!-- 单个书签项 -->
                            <Border Padding="12,8"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="BookmarkItem_MouseLeftButtonDown"
                                    Tag="{Binding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>  <!-- 图标 -->
                                        <ColumnDefinition Width="*"/>     <!-- 详情 -->
                                        <ColumnDefinition Width="Auto"/>  <!-- 删除按钮 -->
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 网站图标 -->
                                    <Image Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                           Width="20" Height="20"
                                           Source="{Binding FaviconUrl}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"
                                           Stretch="Uniform"/>

                                    <!-- 书签标题 -->
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Title}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Title}"/>

                                    <!-- URL 和文件夹标签 -->
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding Url}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="200"
                                                   ToolTip="{Binding Url}"/>

                                        <!-- 文件夹标签 -->
                                        <Border Background="{DynamicResource AccentBrush}" CornerRadius="2"
                                                Padding="4,1" Margin="6,0,0,0"
                                                Visibility="{Binding Folder, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{Binding Folder}"
                                                       Foreground="White" FontSize="9"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- 删除按钮 -->
                                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                            Content="✕" Width="24" Height="24"
                                            Background="Transparent" Foreground="{DynamicResource SecondaryTextBrush}"
                                            BorderThickness="0" FontSize="12" Cursor="Hand"
                                            Click="DeleteBookmark_Click"
                                            Tag="{Binding}"
                                            ToolTip="删除书签"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 空状态提示 -->
                <TextBlock x:Name="EmptyState"
                           Text="暂无书签"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,40,0,0"/>
            </Grid>
        </ScrollViewer>

        <!-- ===== 添加书签按钮 ===== -->
        <Border Grid.Row="3" Padding="12,8"
                Background="{DynamicResource PanelHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Button Height="32" Content="+ 添加当前页面为书签"
                    Background="{DynamicResource AccentBrush}" Foreground="White"
                    BorderThickness="0" FontSize="13" Cursor="Hand"
                    Command="{Binding DataContext.ToggleBookmarkCommand,
                              RelativeSource={RelativeSource AncestorType=Window}}"
                    ToolTip="将当前页面添加到书签 (Ctrl+D)"/>
        </Border>
    </Grid>
</UserControl>
