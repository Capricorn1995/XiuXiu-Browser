<!-- 嗅嗅浏览器 - 主窗口 -->
<Window x:Class="XiuXiu.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:converters="clr-namespace:XiuXiu.Converters"
        Title="嗅嗅浏览器"
        Height="800"
        Width="1280"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:UrlToImageConverter x:Key="UrlToImage"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== 顶部工具栏 ===== -->
        <Border Grid.Row="0" Padding="8,6"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 导航按钮 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Width="32" Height="28" Content="◀" ToolTip="后退"
                            Command="{Binding GoBackCommand}"/>
                    <Button Width="32" Height="28" Content="▶" ToolTip="前进"
                            Command="{Binding GoForwardCommand}"/>
                    <Button Width="32" Height="28" Content="↻" ToolTip="刷新"
                            Command="{Binding ReloadCommand}"/>
                </StackPanel>

                <!-- 地址栏 -->
                <TextBox x:Name="AddressBar" Grid.Column="1" Margin="8,0" Height="28"
                         Text="{Binding AddressBarText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         Background="{StaticResource CardBackgroundBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1" Padding="8,0"
                         KeyDown="AddressBar_KeyDown"/>

                <!-- 功能按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Height="28" Margin="2,0" Padding="8,0" FontWeight="Bold"
                            Foreground="{StaticResource AccentBrush}" Content="🔍嗅一嗅"
                            Command="{Binding SniffMediaCommand}" ToolTip="嗅探页面媒体资源"/>
                    <Button Width="32" Height="28" Content="☆" ToolTip="书签"
                            Command="{Binding ToggleBookmarkCommand}"/>
                    <Button Width="32" Height="28" Content="⬇" ToolTip="下载管理"
                            Command="{Binding ToggleDownloadPanelCommand}"/>
                    <Button Width="32" Height="28" Content="🕐" ToolTip="历史记录"
                            Command="{Binding ToggleHistoryPanelCommand}"/>
                    <Button Width="32" Height="28" Content="⚙" ToolTip="设置"
                            Command="{Binding ToggleSettingsPanelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 主内容区 ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- WebView2 浏览器控件 -->
            <Grid Grid.Column="0">
                <wv2:WebView2 x:Name="BrowserWebView" />
                
                <!-- 加载进度条 -->
                <ProgressBar Height="3"
                             Maximum="100"
                             Value="{Binding LoadingProgress}"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                             VerticalAlignment="Top"
                             Foreground="{StaticResource AccentBrush}"
                             Background="Transparent"
                             BorderThickness="0"/>
            </Grid>

            <!-- 侧边媒体面板 -->
            <Border Grid.Column="1" Width="320"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0"
                    Visibility="{Binding IsMediaPanelOpen, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 面板标题 -->
                    <Border Grid.Row="0" Padding="12,10"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="嗅探结果" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Margin="8,0,0,0" Foreground="{StaticResource AccentBrush}">
                                <Run Text="(" /><Run Text="{Binding ExtractedCount}" /><Run Text=" 个资源)" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 媒体列表 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ExtractedMedia}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Image Grid.Column="0" Width="52" Height="52"
                                                   Stretch="UniformToFill"
                                                   Source="{Binding Url, Converter={StaticResource UrlToImage}}"/>
                                            <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SourceElement}" FontSize="11"
                                                           Foreground="{StaticResource AccentBrush}"/>
                                                <TextBlock Text="{Binding Url}" FontSize="10"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" Width="28" Height="28" Content="⬇" FontSize="12"
                                                    ToolTip="下载此资源"
                                                    Command="{Binding DataContext.DownloadSingleMediaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 底部操作栏 -->
                    <Border Grid.Row="2" Padding="12,8"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Button Height="32" Content="一键保存全部" FontSize="13"
                                Command="{Binding DownloadAllMediaCommand}"
                                Background="{StaticResource AccentBrush}" Foreground="White"
                                BorderThickness="0" Cursor="Hand"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== 状态栏 ===== -->
        <Border Grid.Row="2" Padding="8,4"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" FontSize="12"
                       Foreground="{StaticResource SecondaryTextBrush}"/>
        </Border>
    </Grid>
</Window>
