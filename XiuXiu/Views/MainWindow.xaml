<!-- 嗅嗅浏览器 - 主窗口视图 -->
<Window x:Class="XiuXiu.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:XiuXiu.Converters"
        Title="嗅嗅浏览器"
        Height="800"
        Width="1280"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏：导航按钮 + 地址栏 + 功能按钮 -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 导航按钮 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding GoBackCommand}" Content="◀"
                            ToolTip="后退 (Alt+←)"/>
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding GoForwardCommand}" Content="▶"
                            ToolTip="前进 (Alt+→)"/>
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding ReloadCommand}" Content="↻"
                            ToolTip="刷新 (F5)"/>
                </StackPanel>

                <!-- 地址栏 -->
                <TextBox Grid.Column="1" Margin="8,0" Height="28"
                         Text="{Binding AddressBarText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         Background="{StaticResource CardBackgroundBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1"
                         Padding="8,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding NavigateToUrlCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- 功能按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- 嗅一嗅 按钮 -->
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding SniffMediaCommand}" Content="🔍嗅一嗅"
                            ToolTip="嗅探当前页面媒体资源" FontWeight="Bold"
                            Foreground="{StaticResource AccentBrush}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding ToggleBookmarkCommand}" Content="☆"
                            ToolTip="添加/移除书签"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding ToggleDownloadPanelCommand}" Content="⬇"
                            ToolTip="下载管理"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding ToggleHistoryPanelCommand}" Content="🕐"
                            ToolTip="历史记录"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding ToggleSettingsPanelCommand}" Content="⚙"
                            ToolTip="设置"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- WebView 内容区 -->
            <Border Grid.Column="0"
                    Background="{StaticResource CardBackgroundBrush}">
                <Grid>
                    <!-- 加载进度条 -->
                    <ProgressBar Height="3"
                                 Maximum="100"
                                 Value="{Binding LoadingProgress}"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                                 VerticalAlignment="Top"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"/>

                    <!-- WebView 占位 -->
                    <TextBlock Text="WebView2 浏览器核心区域"
                               Style="{StaticResource SecondaryTextStyle}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14"/>
                </Grid>
            </Border>

            <!-- 侧边媒体面板 -->
            <Border Grid.Column="1"
                    Width="320"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding IsMediaPanelOpen, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 面板标题 -->
                    <Border Grid.Row="0" Padding="12,10"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="嗅探结果" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Margin="8,0,0,0"
                                       Foreground="{StaticResource AccentBrush}">
                                <Run Text="(" />
                                <Run Text="{Binding ExtractedCount}" />
                                <Run Text=" 个资源)" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 媒体列表 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ExtractedMedia}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Background="Transparent">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 缩略图占位 -->
                                            <Border Grid.Column="0" Width="52" Height="52"
                                                    Background="{StaticResource PanelBackgroundBrush}">
                                                <TextBlock Text="{Binding Type}"
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                            </Border>

                                            <!-- URL 信息 -->
                                            <StackPanel Grid.Column="1" Margin="8,0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SourceElement}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource AccentBrush}"/>
                                                <TextBlock Text="{Binding Url}"
                                                           FontSize="10"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                            </StackPanel>

                                            <!-- 下载按钮 -->
                                            <Button Grid.Column="2" Width="28" Height="28"
                                                    Style="{StaticResource ToolbarButtonStyle}"
                                                    Content="⬇" FontSize="12"
                                                    ToolTip="下载此资源"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 底部操作栏 -->
                    <Border Grid.Row="2" Padding="12,8"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Button Height="32"
                                Command="{Binding DownloadAllMediaCommand}"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                Content="一键保存全部"
                                FontSize="13"
                                Cursor="Hand"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <TextBlock Text="{Binding StatusText}"
                       Style="{StaticResource SecondaryTextStyle}"
                       FontSize="12"/>
        </Border>
    </Grid>
</Window>
