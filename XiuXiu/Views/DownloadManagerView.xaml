<!-- 嗅嗅浏览器 - 下载管理器视图 -->
<!-- 展示活跃和已完成的下载任务 -->
<UserControl x:Class="XiuXiu.Views.DownloadManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:XiuXiu.Converters"
             xmlns:models="clr-namespace:XiuXiu.Models"
             Width="360">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
        <converters:DownloadStatusToIconConverter x:Key="StatusToIcon"/>
    </UserControl.Resources>

    <!-- 下载管理器布局 -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 头部 -->
            <RowDefinition Height="*"/>     <!-- 下载列表 -->
            <RowDefinition Height="Auto"/>  <!-- 底部操作 -->
        </Grid.RowDefinitions>

        <!-- ===== 头部 ===== -->
        <Border Grid.Row="0" Padding="12,10"
                Background="{DynamicResource PanelHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="⬇" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="下载管理" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1" Content="清除已完成" FontSize="11"
                        Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding ClearCompletedCommand}"
                        ToolTip="清除已完成的下载记录"/>
            </Grid>
        </Border>

        <!-- ===== 下载列表 ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
            <ItemsControl ItemsSource="{Binding Downloads}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:DownloadItem}">
                        <!-- 单个下载项 -->
                        <Border Padding="12,8"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>  <!-- 图标 -->
                                    <ColumnDefinition Width="*"/>     <!-- 详情 -->
                                    <ColumnDefinition Width="Auto"/>  <!-- 操作按钮 -->
                                </Grid.ColumnDefinitions>

                                <!-- 文件图标 -->
                                <TextBlock Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                                           Text="{Binding Status, Converter={StaticResource StatusToIcon}}"
                                           FontSize="24" VerticalAlignment="Center" Margin="0,0,8,0"/>

                                <!-- 文件名 -->
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding FileName}"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontSize="13" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding FileName}"/>

                                <!-- 进度条和状态 -->
                                <Grid Grid.Row="1" Grid.Column="1" Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 进度条 -->
                                    <ProgressBar Grid.Column="0" Height="4"
                                                 Minimum="0" Maximum="100"
                                                 Value="{Binding Progress}">
                                        <ProgressBar.Style>
                                            <Style TargetType="ProgressBar">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                        <Setter Property="Foreground" Value="#F44336"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                        <Setter Property="Foreground" Value="#FF9800"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ProgressBar.Style>
                                    </ProgressBar>

                                    <!-- 进度文本 -->
                                    <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat='{}{0:F0}%'}"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontSize="10" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- 状态文本和文件大小 -->
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Queued">
                                                        <Setter Property="Text" Value="排队中"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                        <Setter Property="Text" Value="下载中"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                        <Setter Property="Text" Value="已暂停"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Text" Value="已完成"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                        <Setter Property="Text" Value="{Binding ErrorMessage}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                        <Setter Property="Text" Value="已取消"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Text=" · " Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding TotalBytes, Converter={StaticResource FileSizeConverter}}"
                                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                </StackPanel>

                                <!-- 操作按钮 -->
                                <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="2"
                                            Orientation="Horizontal" Margin="8,0,0,0">
                                    <!-- 暂停/恢复按钮 -->
                                    <Button Content="⏸" Width="28" Height="28"
                                            Background="Transparent" Foreground="{DynamicResource SecondaryTextBrush}"
                                            BorderThickness="0" FontSize="14" Cursor="Hand"
                                            ToolTip="暂停">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                        <Setter Property="Command"
                                                                Value="{Binding DataContext.PauseDownloadCommand,
                                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                        <Setter Property="CommandParameter" Value="{Binding}"/>
                                                        <Setter Property="Content" Value="⏸"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                        <Setter Property="Command"
                                                                Value="{Binding DataContext.ResumeDownloadCommand,
                                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                        <Setter Property="CommandParameter" Value="{Binding}"/>
                                                        <Setter Property="Content" Value="▶"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- 取消按钮 -->
                                    <Button Content="✕" Width="28" Height="28"
                                            Background="Transparent" Foreground="#F44336"
                                            BorderThickness="0" FontSize="14" Cursor="Hand"
                                            Command="{Binding DataContext.CancelDownloadCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="取消下载"
                                            Visibility="{Binding Status,
                                                         Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 空状态提示 -->
            <TextBlock x:Name="EmptyState"
                       Text="暂无下载任务"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,40,0,0"/>
            </Grid>
        </ScrollViewer>

        <!-- ===== 底部 ===== -->
        <Border Grid.Row="2" Padding="12,8"
                Background="{DynamicResource PanelHeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{Binding ActiveCount, StringFormat='活跃: {0}'}"
                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,16,0"/>
                <TextBlock Text="{Binding CompletedCount, StringFormat='已完成: {0}'}"
                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
