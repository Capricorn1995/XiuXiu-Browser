<!-- 嗅嗅浏览器 - 全屏图片库视图 -->
<!-- 全屏窗口用于浏览图片，支持缩放、平移和键盘导航 -->
<Window x:Class="XiuXiu.Views.GalleryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:XiuXiu.Converters"
        Title="图片浏览"
        WindowStyle="None"
        WindowState="Maximized"
        Background="Black"
        Topmost="True"
        AllowsTransparency="True"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <!-- 主布局：图片显示区 + 底部控制栏 -->
    <Grid>
        <!-- 图片显示区域 -->
        <Grid x:Name="ImageContainer"
              Background="Black"
              ClipToBounds="True"
              MouseWheel="ImageContainer_MouseWheel"
              MouseLeftButtonDown="ImageContainer_MouseLeftButtonDown"
              MouseMove="ImageContainer_MouseMove"
              MouseLeftButtonUp="ImageContainer_MouseLeftButtonUp">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                    <TranslateTransform x:Name="ImageTranslate" X="0" Y="0"/>
                </TransformGroup>
            </Grid.RenderTransform>

            <Image x:Name="GalleryImage"
                   Source="{Binding CurrentItem.Url}"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- 加载中提示 -->
            <TextBlock x:Name="LoadingText"
                       Text="加载中..."
                       Foreground="#888888"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"/>
        </Grid>

        <!-- 底部控制栏（自动隐藏） -->
        <Border x:Name="ControlBar"
                VerticalAlignment="Bottom"
                Background="#CC000000"
                Padding="16,8"
                Height="64">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- 上一张 -->
                    <ColumnDefinition Width="*"/>      <!-- 位置指示 -->
                    <ColumnDefinition Width="Auto"/>   <!-- 下一张 -->
                    <ColumnDefinition Width="Auto"/>   <!-- 缩放控制 -->
                    <ColumnDefinition Width="Auto"/>   <!-- 下载 -->
                    <ColumnDefinition Width="Auto"/>   <!-- 关闭 -->
                </Grid.ColumnDefinitions>

                <!-- 上一张按钮 -->
                <Button Grid.Column="0" Content="◀ 上一张"
                        Style="{StaticResource GalleryControlButton}"
                        Command="{Binding PreviousCommand}"
                        ToolTip="上一张 (←)"/>

                <!-- 位置指示器 -->
                <TextBlock Grid.Column="1" Text="{Binding PositionText}"
                           Foreground="White" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <!-- 下一张按钮 -->
                <Button Grid.Column="2" Content="下一张 ▶"
                        Style="{StaticResource GalleryControlButton}"
                        Command="{Binding NextCommand}"
                        ToolTip="下一张 (→)"/>

                <!-- 缩放控制 -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="24,0">
                    <Button Content="−" Width="32" Height="32"
                            Style="{StaticResource GalleryControlButton}"
                            Command="{Binding ZoomOutCommand}"
                            ToolTip="缩小 (Ctrl+-)"/>
                    <TextBlock Text="{Binding ZoomLevel, StringFormat='{}{0:0%}'}"
                               Foreground="White" FontSize="12"
                               VerticalAlignment="Center" Margin="8,0" Width="40"
                               TextAlignment="Center"/>
                    <Button Content="+" Width="32" Height="32"
                            Style="{StaticResource GalleryControlButton}"
                            Command="{Binding ZoomInCommand}"
                            ToolTip="放大 (Ctrl++)"/>
                    <Button Content="↺" Width="32" Height="32"
                            Style="{StaticResource GalleryControlButton}"
                            Command="{Binding ResetZoomCommand}"
                            ToolTip="重置缩放"
                            Margin="4,0,0,0"/>
                </StackPanel>

                <!-- 下载按钮 -->
                <Button Grid.Column="4" Content="⬇ 下载"
                        Style="{StaticResource GalleryControlButton}"
                        Command="{Binding DownloadCurrentCommand}"
                        ToolTip="下载当前图片 (Ctrl+S)"
                        Margin="16,0,0,0"/>

                <!-- 关闭按钮 -->
                <Button Grid.Column="5" Content="✕ 关闭"
                        Style="{StaticResource GalleryControlButton}"
                        Click="CloseButton_Click"
                        ToolTip="关闭 (Esc)"
                        Margin="8,0,0,0"/>
            </Grid>
        </Border>
    </Grid>

    <Window.Resources>
        <ResourceDictionary>
            <!-- 图库控制按钮样式 -->
            <Style x:Key="GalleryControlButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#44FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
</Window>
