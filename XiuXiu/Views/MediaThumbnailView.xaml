<!-- 嗅嗅浏览器 - 媒体缩略图视图 -->
<!-- 单个媒体缩略图卡片，显示图片/视频预览、类型图标和来源信息 -->
<UserControl x:Class="XiuXiu.Views.MediaThumbnailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:XiuXiu.Models"
             Width="140" Height="140">

    <!-- 缩略图卡片布局 -->
    <Border Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Cursor="Hand">
        <Grid>
            <!-- 图片显示 -->
            <Image Source="{Binding ThumbnailUrl}"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

            <!-- 类型图标叠加层（右上角） -->
            <Border Background="#99000000" CornerRadius="3"
                    Padding="4,2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="4">
                <TextBlock FontSize="9" Foreground="White">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Type}" Value="Image">
                                    <Setter Property="Text" Value="🖼"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}" Value="Video">
                                    <Setter Property="Text" Value="▶"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- 来源元素标签（底部） -->
            <Border Background="#99000000" CornerRadius="0,0,6,6"
                    VerticalAlignment="Bottom" Padding="4,2">
                <TextBlock Text="{Binding SourceElement}"
                           FontSize="9" Foreground="#CCCCCC"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding SourceElement}"/>
            </Border>

            <!-- 选中标记（选中时显示蓝色边框） -->
            <Border BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="0" CornerRadius="6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <!-- 下载按钮（悬停时显示） -->
            <Button Content="⬇" Width="28" Height="28"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="4"
                    Background="#CC000000" Foreground="White"
                    BorderThickness="0" CornerRadius="4"
                    FontSize="14" Cursor="Hand"
                    Visibility="Collapsed"
                    x:Name="DownloadButton"
                    ToolTip="下载此资源">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>

    <!-- 鼠标悬停时显示下载按钮 -->
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
            <EventTrigger.Actions>
                <BeginStoryboard>
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DownloadButton"
                                                       Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger.Actions>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseLeave">
            <EventTrigger.Actions>
                <BeginStoryboard>
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DownloadButton"
                                                       Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger.Actions>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>
