<!-- 嗅嗅浏览器 - 地址栏视图 -->
<!-- 包含导航按钮、URL 输入框和主要操作按钮 -->
<UserControl x:Class="XiuXiu.Views.AddressBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 水平布局：导航按钮 | URL 输入框 | 操作按钮 -->
    <StackPanel Orientation="Horizontal">
        <!-- 导航按钮组：后退、前进、刷新/停止 -->
        <StackPanel Orientation="Horizontal" Margin="4,0">
            <!-- 后退按钮 -->
            <Button Width="32" Height="32" Content="←"
                    Style="{StaticResource NavButtonStyle}"
                    Command="{Binding GoBackCommand}"
                    ToolTip="后退 (Alt+←)"/>

            <!-- 前进按钮 -->
            <Button Width="32" Height="32" Content="→"
                    Style="{StaticResource NavButtonStyle}"
                    Command="{Binding GoForwardCommand}"
                    ToolTip="前进 (Alt+→)"/>

            <!-- 刷新/停止按钮 -->
            <Button Width="32" Height="32" Content="↻"
                    Style="{StaticResource NavButtonStyle}"
                    Command="{Binding ReloadCommand}"
                    ToolTip="刷新 (F5)"/>
        </StackPanel>

        <!-- URL 地址栏输入框 -->
        <TextBox x:Name="UrlTextBox"
                 Margin="8,0"
                 Style="{StaticResource AddressBarStyle}"
                 Text="{Binding AddressBarText, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="输入网址或搜索关键词">
            <TextBox.InputBindings>
                <KeyBinding Key="Enter" Command="{Binding NavigateToUrlCommand}"/>
            </TextBox.InputBindings>
        </TextBox>

        <!-- 操作按钮组 -->
        <StackPanel Orientation="Horizontal" Margin="4,0">
            <!-- 书签切换按钮 -->
            <Button Width="32" Height="32" Content="☆"
                    Style="{StaticResource NavButtonStyle}"
                    Command="{Binding ToggleBookmarkCommand}"
                    ToolTip="添加/移除书签 (Ctrl+D)"/>

            <!-- 嗅一嗅主按钮 -->
            <Button Height="32" MinWidth="100" Content="🔍 嗅一嗅"
                    Style="{StaticResource SniffButtonStyle}"
                    Command="{Binding SniffMediaCommand}"
                    ToolTip="嗅探当前页面中的图片和视频资源"
                    Margin="8,0"/>

            <!-- 更多菜单按钮 -->
            <Button Width="32" Height="32" Content="⋯"
                    Style="{StaticResource NavButtonStyle}"
                    ToolTip="更多功能"/>
        </StackPanel>
    </StackPanel>
</UserControl>
