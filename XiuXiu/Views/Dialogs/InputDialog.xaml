<!-- 嗅嗅浏览器 - 输入对话框 -->
<!-- 模态输入对话框，带标题、提示文本、输入框和确认/取消按钮 -->
<Window x:Class="XiuXiu.Views.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入"
        Width="400"
        Height="190"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <!-- 对话框内容 -->
    <Border Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <TextBlock x:Name="TitleText" Grid.Row="0"
                       Text="输入"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Margin="0,0,0,12"/>

            <!-- 提示文本 -->
            <TextBlock x:Name="PromptText" Grid.Row="1"
                       Text="请输入："
                       FontSize="13"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,0,0,8"/>

            <!-- 输入框 -->
            <TextBox x:Name="InputTextBox" Grid.Row="2"
                     Height="32"
                     Background="{DynamicResource InputBackgroundBrush}"
                     Foreground="{DynamicResource PrimaryTextBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     Padding="8,4"
                     FontSize="13"
                     Margin="0,0,0,16">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=OkCommand}"/>
                </TextBox.InputBindings>
            </TextBox>

            <!-- 按钮区域 -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="取消"
                        Width="80" Height="32"
                        Background="{DynamicResource InputBackgroundBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        FontSize="13" Cursor="Hand"
                        Margin="0,0,8,0"
                        Click="CancelButton_Click"/>

                <Button x:Name="OkButton" Content="确定"
                        Width="80" Height="32"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        CornerRadius="4"
                        FontSize="13" Cursor="Hand"
                        Click="OkButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
